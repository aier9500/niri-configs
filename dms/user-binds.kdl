// User overrides — kept separate so `dms setup binds` never clobbers them.
binds {
    Super+E hotkey-overlay-title="Files" { spawn "nautilus"; }
    Super+B hotkey-overlay-title="Zen Browser" { spawn "flatpak" "run" "app.zen_browser.zen"; }
    Super+Return hotkey-overlay-title="Open Terminal" { spawn "ghostty"; }

    // Windows-style snip (Super+Shift+S) -> niri interactive screenshot UI.
    Super+Shift+S hotkey-overlay-title="Screenshot region" { screenshot; }

    // GNOME parity: Super+M = notifications (task mgr stays on Ctrl+Alt+Del).
    Super+M hotkey-overlay-title="Notifications" { spawn "dms" "ipc" "call" "notifications" "toggle"; }
    // Close window on both Super+X and Alt+F4. Logout lives in the Ctrl+Alt+Del power menu.
    Super+X hotkey-overlay-title="Close window" { close-window; }
    Alt+F4 hotkey-overlay-title="Close window" { close-window; }

    // App launcher: Super+A (GNOME show-apps parity).
    Super+A hotkey-overlay-title="App Launcher" { spawn "dms" "ipc" "call" "spotlight" "toggle"; }

    // Switch keyboard layout / language (needs 2+ xkb layouts configured).
    Super+Space hotkey-overlay-title="Switch language" { switch-layout "next"; }
}
