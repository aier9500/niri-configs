// niri config — DMS-integrated.
// Base kept minimal; themeable pieces live in ./dms/*.kdl (regenerate via `dms setup <piece>`).
// KDL format: https://niri-wm.github.io/niri/Configuration:-Introduction

// ---- DMS includes (order: colors first so later layout can override) ----
include "dms/colors.kdl"
include "dms/layout.kdl"
include "dms/binds.kdl"
include "dms/user-binds.kdl"
include "dms/alttab.kdl"
include "dms/windowrules.kdl"
include "dms/outputs.kdl"
include "dms/cursor.kdl"

// ---- Input (laptop) ----
input {
    keyboard {
        xkb {
            // Empty -> inherits from localectl / org.freedesktop.locale1.
        }
        numlock
    }

    touchpad {
        tap
        natural-scroll
        dwt              // disable-while-typing — uncomment if palm rejection wanted
        // accel-speed 0.2
    }

    mouse {
        // natural-scroll
        accel-profile "flat"   // disable pointer acceleration (raw 1:1 movement)
    }

    // Hyprland-style: focus follows mouse hover anywhere + cursor warps to keyboard-focused window.
    focus-follows-mouse
    warp-mouse-to-focus
}

// ---- Autostart ----
spawn-at-startup "dms" "run"                                         // DankMaterialShell
spawn-at-startup "/usr/libexec/polkit-gnome-authentication-agent-1"  // polkit prompts

// ---- Blur ----
// niri blur is GLOBAL — it blurs behind any translucent surface (windows + layer panels).
// Not per-app scopable in 26.04. Only visible where a surface is actually translucent:
//   - ghostty: set `background-opacity` < 1 (+ `background-blur`) in its config
//   - Zen: translucent only via userChrome tweaks
//   - overview: shows this same blur behind translucent windows
blur {
    on
    passes 2
    noise 0.02
}

// ---- Misc ----
prefer-no-csd
screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

hotkey-overlay {
    skip-at-startup
}

environment {
    // Session runs on AMD iGPU (cardwire integrated). NVIDIA-offload apps set PRIME vars themselves.
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    QT_QPA_PLATFORM "wayland;xcb"
    NIXOS_OZONE_WL "1"
}
